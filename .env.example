# Copy this file to .env.local and fill in your Supabase project's values.
# Find both under Project Settings -> API in your Supabase dashboard.
# These are safe to expose to the browser (NEXT_PUBLIC_*) — Supabase's
# anon key is meant to be used client-side and is restricted by the
# table's Row Level Security policies (see supabase/schema.sql).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
